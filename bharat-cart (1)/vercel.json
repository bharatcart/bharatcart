{
  "version": 2,
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/payment/create",
      "destination": "/api/payment-create.js"
    },
    {
      "source": "/api/payment/verify",
      "destination": "/api/payment-verify.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
